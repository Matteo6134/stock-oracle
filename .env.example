# Stock Oracle Configuration
# Copy this to .env and fill in your API keys

# NewsAPI - Get free key at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage - Get free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# Server Port
PORT=4000

# CORS allowed origins (comma-separated)
# Set this on Railway to include your Vercel frontend URL
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5174

# Frontend API URL (set on Vercel to point to Railway backend)
# VITE_API_URL=https://your-railway-app.up.railway.app
